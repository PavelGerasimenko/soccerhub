{
  "name": "soccerhub-backend",
  "version": "1.0.0",
  "description": "SoccerHub Backend API - Phase 1: User Management Service",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "keywords": [
    "soccer",
    "sports",
    "api",
    "backend"
  ],
  "author": "SoccerHub Team",
  "license": "MIT",
  "dependencies": {
    "express": "4.18.2",
    "bcrypt": "5.1.0",
    "jsonwebtoken": "9.0.2",
    "dotenv": "16.3.1",
    "pg": "8.11.3",
    "redis": "4.6.11",
    "cors": "2.8.5",
    "helmet": "7.0.0",
    "express-validator": "7.0.0",
    "uuid": "9.0.0",
    "socket.io": "4.7.2"
  },
  "devDependencies": {
    "@types/express": "4.17.21",
    "@types/node": "20.10.6",
    "@types/bcrypt": "5.0.2",
    "@types/jsonwebtoken": "9.0.7",
    "@types/jest": "29.5.11",
    "@types/cors": "2.8.17",
    "@types/pg": "8.11.3",
    "typescript": "5.3.3",
    "tsx": "4.7.0",
    "jest": "29.7.0",
    "ts-jest": "29.1.1",
    "supertest": "6.3.3",
    "@types/supertest": "2.0.12",
    "@types/uuid": "9.0.7",
    "eslint": "8.56.0",
    "@typescript-eslint/eslint-plugin": "6.16.0",
    "@typescript-eslint/parser": "6.16.0",
    "eslint-config-airbnb-base": "15.0.0",
    "eslint-plugin-import": "2.29.1",
    "prettier": "3.1.1"
  }
}
